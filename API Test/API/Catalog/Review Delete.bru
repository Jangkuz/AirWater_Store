meta {
  name: Review Delete
  type: http
  seq: 10
}

delete {
  url: {{catalog_url}}/reviews/{{reviewCreatedId}}
  body: none
  auth: inherit
}

body:json {
  {
      "Id": {{reviewCreatedId}},
      "Rating": 5,
      "Comment": "A must play, I put 40 hours into it!"
  }
}

assert {
  res.status: eq 200
  res.body.isSuccess: isTruthy
}

settings {
  encodeUrl: true
  timeout: 0
}
