meta {
  name: Game Update
  type: http
  seq: 4
}

post {
  url: {{catalog_url}}/games
  body: json
  auth: inherit
}

body:json {
  {
    "Id": {{gameCreatedId}},
    "Title": "Epic Battle Fantasy 5",
    "ThumbnailUrl": "string",
    "Description": "A casual JRPG game made by MattRoszak",
    "Genre": [
      "string1",
      "string2"
    ],
    "Developer": "MattRoszak",
    "Publisher": "Kupo Game",
    "ReleaseDate": "2025-06-23",
    "Price": 2,
    "Quantity": 2
  }
}

assert {
  res.status: eq 201
  res.body.id: isNumber
}

script:post-response {
  const body = res.getBody();
  
  if(body){
    bru.setVar("gameCreatedId", body.id);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
